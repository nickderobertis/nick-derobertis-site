{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@site/design-system": ["libs/design-system/src/index.ts"],
      "@site/data-access": ["libs/data-access/src/index.ts"],
      "@site/analytics": ["libs/analytics/src/index.ts"],
      "@site/layout": ["libs/layout/src/index.ts"],
      "@site/ui": ["libs/ui/src/index.ts"]
    }
  }
}
