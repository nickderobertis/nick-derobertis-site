{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@site/design-system": ["libs/design-system/src/index.ts"],
      "@site/data-access-core": ["libs/data-access-core/src/index.ts"],
      "@site/data-access-awards": ["libs/data-access-awards/src/index.ts"],
      "@site/data-access-skills": ["libs/data-access-skills/src/index.ts"],
      "@site/data-access-home": ["libs/data-access-home/src/index.ts"],
      "@site/data-access-timeline": ["libs/data-access-timeline/src/index.ts"],
      "@site/data-access-research": ["libs/data-access-research/src/index.ts"],
      "@site/data-access-software": ["libs/data-access-software/src/index.ts"],
      "@site/data-access-courses": ["libs/data-access-courses/src/index.ts"],
      "@site/analytics": ["libs/analytics/src/index.ts"],
      "@site/route-state": ["libs/route-state/src/index.ts"],
      "@site/layout": ["libs/layout/src/index.ts"],
      "@site/ui": ["libs/ui/src/index.ts"],
      "@site/build-config": ["libs/build-config/src/index.ts"]
    }
  }
}
