{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.spec.tsx"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/biome.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{options.outputPath}"]
    },
    "test": { "cache": true },
    "lint": { "cache": true },
    "typecheck": { "cache": true },
    "screenshot": {
      "cache": false,
      "dependsOn": [
        "build",
        {
          "target": "build",
          "projects": [
            "home",
            "home-carousel",
            "home-contact",
            "home-cards",
            "home-story",
            "timeline",
            "skills",
            "awards"
          ]
        },
        { "target": "prerender", "projects": ["shell"] }
      ],
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/scripts/capture-visual.mjs",
        "{workspaceRoot}/scripts/e2e-data-provider.mjs",
        "{workspaceRoot}/visual-projects.json",
        "{workspaceRoot}/scripts/visual-project.sh",
        "{workspaceRoot}/screencomp.toml",
        "{projectRoot}/visual/baseline/**/*"
      ],
      "outputs": ["{projectRoot}/visual/current", "{projectRoot}/visual/verify"]
    }
  },
  "plugins": []
}
