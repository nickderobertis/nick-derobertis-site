{
  "name": "layout",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/layout/src",
  "projectType": "library",
  "tags": ["type:layout", "scope:layout"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "biome lint libs/layout" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/layout/tsconfig.json" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config libs/layout/vite.config.ts --coverage"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/layout/tsconfig.json" }
    }
  }
}
