{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/design-system/src",
  "projectType": "library",
  "tags": ["type:shared", "scope:design-system"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "biome lint libs/design-system" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/design-system/tsconfig.json" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests libs/design-system"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/design-system/tsconfig.json" }
    }
  }
}
