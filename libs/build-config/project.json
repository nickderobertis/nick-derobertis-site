{
  "name": "build-config",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/build-config/src",
  "projectType": "library",
  "tags": ["type:shared", "scope:build"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "biome lint libs/build-config" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/build-config/tsconfig.json" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/build-config/tsconfig.json" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --passWithNoTests libs/build-config" }
    }
  }
}
