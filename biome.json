{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist",
      "!coverage",
      "!.nx",
      "!node_modules",
      "!playwright-report",
      "!test-results",
      "!reference"
    ]
  },
  "formatter": { "enabled": true, "indentStyle": "space" },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error"
      }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double" } }
}
