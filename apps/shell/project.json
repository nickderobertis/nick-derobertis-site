{
  "name": "shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/shell/src",
  "projectType": "application",
  "tags": ["type:app", "scope:shell"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/shell"],
      "options": {
        "command": "rsbuild build --config apps/shell/rsbuild.config.ts"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rsbuild dev --config apps/shell/rsbuild.config.ts"
      }
    },
    "prerender": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build",
        {
          "target": "build",
          "projects": [
            "home",
            "home-carousel",
            "home-cards",
            "home-story",
            "home-contact",
            "bio",
            "research",
            "software",
            "courses",
            "timeline",
            "skills",
            "awards"
          ]
        }
      ],
      "options": {
        "command": "node scripts/prerender.mjs && node scripts/check-static-artifact.mjs"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --max-warnings=0 && biome lint apps/shell"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p apps/shell/tsconfig.app.json" }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/shell"],
      "options": {
        "command": "vitest run --config apps/shell/vite.config.ts --coverage"
      }
    }
  }
}
